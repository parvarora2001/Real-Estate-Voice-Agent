# --- Google Gemini (the agent's brain + property embeddings) ---
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# --- Twilio (places the outbound call to the visitor) ---
# A funded/paid account is required to call arbitrary numbers.
# A trial account can ONLY call numbers you have verified in the Twilio console.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# --- Public URL of THIS deployed app (used as the Twilio voice webhook) ---
# On Hugging Face Spaces this looks like: https://<user>-<space>.hf.space
PUBLIC_BASE_URL=https://your-space.hf.space

# Optional overrides
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=text-embedding-004
# PORT=7860
